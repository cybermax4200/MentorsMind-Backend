NODE_ENV=test
PORT=5000
API_VERSION=v1
DATABASE_URL=postgresql://postgres:testpassword@localhost:5432/mentorminds_test
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mentorminds_test
DB_USER=postgres
DB_PASSWORD=testpassword
JWT_SECRET=test-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=test-refresh-key-minimum-32-characters-long
JWT_REFRESH_EXPIRES_IN=30d
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
REDIS_URL=redis://localhost:6379
LOG_LEVEL=error
BCRYPT_ROUNDS=1
PLATFORM_FEE_PERCENTAGE=5

# Firebase Cloud Messaging (Push Notifications)
FIREBASE_PROJECT_ID=test-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntest_private_key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=test@test-project.iam.gserviceaccount.com
MEETING_PROVIDER=daily
MEETING_API_KEY=test_api_key_12345
MEETING_ROOM_EXPIRY_MINUTES=30
MEETING_RETRY_ATTEMPTS=1
